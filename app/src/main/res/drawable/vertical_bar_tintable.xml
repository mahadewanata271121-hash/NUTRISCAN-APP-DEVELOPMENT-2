<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 1. Layer Background (Wadah) - Diubah ke abu-abu sangat muda -->
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="12dp" />
            <solid android:color="#F2F2F2" />
        </shape>
    </item>

    <!-- 2. Layer Progress (Isi) -->
    <item android:id="@android:id/progress">
        <scale android:scaleGravity="bottom" android:scaleHeight="100%">
            <shape>
                <corners android:radius="12dp" />
                <solid android:color="#000000" /> <!-- Warna ini akan ditimpa oleh progressTint di XML layout -->
            </shape>
        </scale>
    </item>
</layer-list>
