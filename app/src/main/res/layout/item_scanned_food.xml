<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#F8F9FA"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Food Photo Container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iv_food_container"
            android:layout_width="64dp"
            android:layout_height="64dp"
            app:cardCornerRadius="14dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#F0F0F0">
            <ImageView
                android:id="@+id/iv_food_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/illustration22"
                android:contentDescription="@null" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/spacelight"
                android:text="Nama Makanan"
                android:textColor="@color/black_deep"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNutrientDetails"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/spacelight"
                android:text="0 kcal | P: 0g | K: 0g | L: 0g"
                android:textColor="@color/black_soft"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/spacelight"
                android:textColor="@color/unselected_date_text"
                android:textSize="11sp"
                tools:text="Senin, 12 Jan 2026 • 12:45" />

        </LinearLayout>

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_favorite_select"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="4dp"
            app:buttonTint="@color/orange_primary"
            android:gravity="center"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone"
            tools:visibility="visible" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="@color/unselected_date_text"
            android:layout_marginEnd="4dp"
            android:contentDescription="@null" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
