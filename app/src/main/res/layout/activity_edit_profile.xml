<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_abstract"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <ImageButton
        android:id="@+id/btn_back_edit_profile"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black_deep" />

    <TextView
        android:id="@+id/tv_title_edit_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/spacelight"
        android:text="@string/label_edit_profile"
        android:textColor="@color/black_deep"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_edit_profile"
        app:layout_constraintStart_toEndOf="@+id/btn_back_edit_profile"
        app:layout_constraintTop_toTopOf="@+id/btn_back_edit_profile" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_back_edit_profile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingHorizontal="24dp">

            <!-- Area Foto Profil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/avatar_container"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="60dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/orange_primary"
                app:strokeWidth="3dp">

                <ImageView
                    android:id="@+id/iv_edit_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/cd_user_avatar"
                    android:scaleType="centerCrop"
                    android:src="@drawable/person" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="12dp"
                android:text="@string/btn_change_photo"
                android:textColor="@color/orange_primary"
                android:textStyle="bold"
                android:fontFamily="@font/spacelight" />

            <!-- Form Input Nama Lengkap -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/orange_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/label_full_name"
                    android:inputType="textPersonName"
                    android:textColor="@color/black_deep"
                    android:textColorHint="@color/black_soft"
                    android:fontFamily="@font/spacelight"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Form Input Email (Disabled) -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:enabled="false"
                app:hintEnabled="false"
                app:boxBackgroundColor="#F5F5F5"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxStrokeWidth="0dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/label_email"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/black_soft"
                    android:textColorHint="@color/black_soft"
                    android:fontFamily="@font/spacelight"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <!-- Form Input Tinggi -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_ruler"
                    app:endIconTint="@color/orange_primary"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:boxStrokeColor="@color/orange_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_edit_height"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_height"
                        android:inputType="number"
                        android:textColor="@color/black_deep"
                        android:textColorHint="@color/black_soft"
                        android:fontFamily="@font/spacelight"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Form Input Berat -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:hintEnabled="false"
                    app:boxBackgroundColor="@color/white"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_weight_scale"
                    app:endIconTint="@color/orange_primary"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="1dp"
                    app:boxStrokeColor="@color/orange_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_edit_weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_weight"
                        android:inputType="numberDecimal"
                        android:textColor="@color/black_deep"
                        android:textColorHint="@color/black_soft"
                        android:fontFamily="@font/spacelight"
                        android:paddingVertical="16dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Form Input Tanggal Lahir -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:hintEnabled="false"
                app:boxBackgroundColor="@color/white"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_calendar"
                app:endIconTint="@color/orange_primary"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="1dp"
                app:boxStrokeColor="@color/orange_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_edit_birthdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="true"
                    android:clickable="true"
                    android:hint="@string/label_birthdate"
                    android:inputType="none"
                    android:textColor="@color/black_deep"
                    android:textColorHint="@color/black_soft"
                    android:fontFamily="@font/spacelight"
                    android:paddingVertical="16dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_gender"
                android:textColor="@color/black_soft"
                android:textSize="14sp"
                android:fontFamily="@font/spacelight"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_edit_gender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_male"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="@string/gender_male"
                    app:buttonTint="@color/orange_primary"
                    app:useMaterialThemeColors="false"
                    android:background="@android:color/transparent"
                    android:textColor="@color/black_medium"
                    android:fontFamily="@font/spacelight"
                    android:paddingVertical="14dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rb_female"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:text="@string/gender_female"
                    app:buttonTint="@color/orange_primary"
                    app:useMaterialThemeColors="false"
                    android:background="@android:color/transparent"
                    android:textColor="@color/black_medium"
                    android:fontFamily="@font/spacelight"
                    android:paddingVertical="14dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </RadioGroup>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_profile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_save_changes"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:fontFamily="@font/spacelight"
                app:backgroundTint="#000000"
                app:cornerRadius="16dp"
                app:elevation="4dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
