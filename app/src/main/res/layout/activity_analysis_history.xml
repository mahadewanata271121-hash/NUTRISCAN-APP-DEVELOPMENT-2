<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_abstract"
    android:fitsSystemWindows="true">

    <!-- Header Section -->
    <ImageButton
        android:id="@+id/btn_back_history"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_back_button"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black_deep" />

    <TextView
        android:id="@+id/tv_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:fontFamily="@font/spacelight"
        android:text="@string/title_history"
        android:textColor="@color/black_deep"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_history"
        app:layout_constraintStart_toEndOf="@+id/btn_back_history"
        app:layout_constraintTop_toTopOf="@+id/btn_back_history" />

    <ImageButton
        android:id="@+id/btn_view_favorites"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginEnd="20dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/cd_view_favorites"
        android:src="@drawable/ic_favorite_filled"
        app:layout_constraintBottom_toBottomOf="@+id/btn_back_history"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_back_history" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_history_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="180dp">

            <!-- KARTU RINGKASAN MINGGUAN -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/spacelight"
                        android:text="@string/label_weekly_average"
                        android:textColor="@color/black_soft"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_average_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/spacelight"
                        android:text="@string/value_default_kcal"
                        android:textColor="@color/black_deep"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        tools:text="1,850 kkal" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:baselineAligned="false"
                        android:gravity="bottom"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <!-- Senin (Orange Pastel) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_senin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_senin" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_orange_soft" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_senin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sen" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Selasa (Blue Pastel) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_selasa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_selasa" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_blue" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_selasa" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sel" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Rabu (Green Healthy) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_rabu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_rabu" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_green_healthy" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_rabu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Rab" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Kamis (Pink Pastel) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_kamis" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_kamis" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_pink" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_kamis" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Kam" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Jumat (Purple Pastel) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_jumat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_jumat" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_purple" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_jumat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Jum" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Sabtu (Yellow Pastel) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_sabtu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_sabtu" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_yellow" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_sabtu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Sab" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                        <!-- Minggu (Mint Green) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center_horizontal" android:orientation="vertical">
                            <TextView android:id="@+id/tv_limit_minggu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2k" android:textColor="@color/black_soft" android:textSize="10sp" android:fontFamily="@font/spacelight" android:textStyle="bold"/>
                            <FrameLayout android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginHorizontal="4dp">
                                <ProgressBar android:id="@+id/bar_minggu" style="@android:style/Widget.ProgressBar.Horizontal" android:layout_width="match_parent" android:layout_height="match_parent" android:progressDrawable="@drawable/vertical_bar_tintable" android:progressTint="@color/illu_mint" android:progress="0"/>
                                <TextView android:id="@+id/tv_val_minggu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="0" android:textColor="@color/white" android:textSize="10sp" android:textStyle="bold"/>
                            </FrameLayout>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Min" android:textColor="@color/black_soft" android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toggle Group (Interval) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="25dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">
                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/interval_toggle_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:checkedButton="@+id/btn_1w"
                    app:selectionRequired="true"
                    app:singleSelection="true">
                    <Button android:id="@+id/btn_1w" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1M" android:textColor="@color/interval_text_color_selector" android:textSize="12sp" android:textStyle="bold" app:backgroundTint="@color/interval_background_selector" app:cornerRadius="25dp" app:strokeWidth="0dp" />
                    <Button android:id="@+id/btn_1m" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1B" android:textColor="@color/interval_text_color_selector" android:textSize="12sp" android:textStyle="bold" app:backgroundTint="@color/interval_background_selector" app:cornerRadius="25dp" app:strokeWidth="0dp" />
                    <Button android:id="@+id/btn_6m" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="6B" android:textColor="@color/interval_text_color_selector" android:textSize="12sp" android:textStyle="bold" app:backgroundTint="@color/interval_background_selector" app:cornerRadius="25dp" app:strokeWidth="0dp" />
                    <Button android:id="@+id/btn_1y" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1T" android:textColor="@color/interval_text_color_selector" android:textSize="12sp" android:textStyle="bold" app:backgroundTint="@color/interval_background_selector" app:cornerRadius="25dp" app:strokeWidth="0dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </com.google.android.material.card.MaterialCardView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/spacelight" android:text="Statistik Nutrisi" android:textColor="@color/black_deep" android:textSize="16sp" android:textStyle="bold" />

            <!-- Chart Cards (WHITE BACKGROUND FOR CLEAN LOOK) -->
            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <TextView android:id="@+id/tv_label_calories" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kalori" android:textColor="@color/card_calories_text" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton android:id="@+id/btn_next_cal" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:rotation="180" android:src="@drawable/ic_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/card_calories_text" />

                    <com.example.nutriscan.MountainChartView android:id="@+id/chart_calories" android:layout_width="match_parent" android:layout_height="140dp" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/tv_label_calories" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <TextView android:id="@+id/tv_label_carbs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Karbohidrat" android:textColor="@color/card_carbs_text" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton android:id="@+id/btn_next_carbs" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:rotation="180" android:src="@drawable/ic_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/card_carbs_text" />

                    <com.example.nutriscan.MountainChartView android:id="@+id/chart_carbs" android:layout_width="match_parent" android:layout_height="140dp" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/tv_label_carbs" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <TextView android:id="@+id/tv_label_protein" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Protein" android:textColor="@color/card_protein_text" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton android:id="@+id/btn_next_prot" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:rotation="180" android:src="@drawable/ic_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/card_protein_text" />

                    <com.example.nutriscan.MountainChartView android:id="@+id/chart_protein" android:layout_width="match_parent" android:layout_height="140dp" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/tv_label_protein" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="24dp" app:cardElevation="2dp" app:strokeWidth="0dp">
                <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="20dp">
                    <TextView android:id="@+id/tv_label_fat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lemak" android:textColor="@color/card_purple_text" android:textStyle="bold" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton android:id="@+id/btn_next_fat" android:layout_width="32dp" android:layout_height="32dp" android:background="?attr/selectableItemBackgroundBorderless" android:rotation="180" android:src="@drawable/ic_back" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:tint="@color/card_purple_text" />

                    <com.example.nutriscan.MountainChartView android:id="@+id/chart_fat" android:layout_width="match_parent" android:layout_height="140dp" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/tv_label_fat" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="32dp" android:layout_marginBottom="16dp" android:fontFamily="@font/spacelight" android:text="Catatan Harian" android:textColor="@color/black_deep" android:textSize="14sp" android:textStyle="bold" />
            <TextView android:id="@+id/tv_food_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="@font/spacelight" android:padding="16dp" android:text="Belum ada catatan makan hari ini." android:textColor="@color/black_medium" android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- Navigation -->
    <com.google.android.material.card.MaterialCardView android:id="@+id/bottom_navigation_container" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="110dp" app:cardBackgroundColor="@color/white" app:cardCornerRadius="35dp" app:cardElevation="8dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:strokeWidth="0dp">
        <LinearLayout android:layout_width="288dp" android:layout_height="53dp" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
            <ImageView android:id="@+id/nav_home_icon" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginHorizontal="3dp" android:background="@drawable/nav_item_background_selector" android:contentDescription="Home" android:padding="10dp" android:src="@drawable/home" app:tint="@color/nav_icon_color_selector" />
            <ImageView android:id="@+id/nav_ai_icon" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginHorizontal="3dp" android:background="@drawable/nav_item_background_selector" android:contentDescription="Scan" android:padding="10dp" android:src="@drawable/scan" app:tint="@color/nav_icon_color_selector" />
            <ImageView android:id="@+id/nav_scan_icon" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginHorizontal="3dp" android:background="@drawable/nav_mark_pink" android:contentDescription="History" android:padding="10dp" android:src="@drawable/statisktik" app:tint="@color/nav_icon_color_selector" />
            <ImageView android:id="@+id/nav_history_icon" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginHorizontal="3dp" android:background="@drawable/nav_item_background_selector" android:contentDescription="Education" android:padding="10dp" android:src="@drawable/edukasi" app:tint="@color/nav_icon_color_selector" />
            <ImageView android:id="@+id/nav_settings_icon" android:layout_width="45dp" android:layout_height="45dp" android:layout_marginHorizontal="3dp" android:background="@drawable/nav_item_background_selector" android:contentDescription="Settings" android:padding="10dp" android:src="@drawable/settings" app:tint="@color/nav_icon_color_selector" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
